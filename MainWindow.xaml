<Window x:Class="SimpleLoginWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pharmacy Management System" 
        Height="720" Width="1280"
        Background="#FFF5F5F5"
        ResizeMode="CanResize">

    <Grid Margin="10">

        <!-- Search Box -->
        <TextBox x:Name="SearchBox"
                 Width="300"
                 Height="40"
                 Margin="10,10,0,0"
                 Padding="5"
                 FontFamily="Georgia"
                 FontSize="16"
                 VerticalAlignment="Top"
                 HorizontalAlignment="Left"
                 Text="Search Medicine..."
                 Foreground="Gray"
                 GotFocus="SearchBox_GotFocus"
                 LostFocus="SearchBox_LostFocus"
                 TextChanged="SearchBox_TextChanged"/>

        <!-- DataGrid -->
        <DataGrid x:Name="MedicinesDataGrid" 
                  AutoGenerateColumns="False"
                  Margin="0,70,0,10"
                  Background="White"
                  Foreground="Black"
                  BorderBrush="#FFB22222"
                  BorderThickness="2"
                  AlternationCount="2"
                  ColumnHeaderHeight="50"
                  RowHeight="80"
                  FontFamily="Georgia"
                  FontSize="16"
                  FontWeight="Bold"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeColumns="True"
                  CanUserResizeRows="False"
                  IsReadOnly="True"
                  HorizontalGridLinesBrush="#FFB22222"
                  VerticalGridLinesBrush="#FFB22222"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="60"/>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="200"/>
                <DataGridTextColumn Header="Quantity" Binding="{Binding Quantity}" Width="120"/>
                <DataGridTextColumn Header="Price" Binding="{Binding Price}" Width="120"/>
                <DataGridTextColumn Header="Expiry Date" Binding="{Binding ExpiryDate}" Width="150"/>
                <DataGridTextColumn Header="Batch No." Binding="{Binding BatchNumber}" Width="120"/>

                <!-- Image Column -->
                <DataGridTemplateColumn Header="Image" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border BorderThickness="1" BorderBrush="Gray" Padding="3">
                                <Image Source="{Binding ImagePath}" 
                           Width="100" Height="100"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="300"/>
            </DataGrid.Columns>

        </DataGrid>

    </Grid>
</Window>
